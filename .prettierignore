# .prettierignore uses gitignore syntax — one pattern per line, no brace expansion.
# A leading-slash-free pattern matches at any depth; *.cjs covers dist/server.bundle.cjs.
*.ts
*.tsx
*.js
*.jsx
*.mjs
*.cjs

