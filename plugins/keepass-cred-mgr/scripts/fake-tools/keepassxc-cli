#!/usr/bin/env bash
# Fake keepassxc-cli for PTH testing.
#
# Two execution modes:
#
#   REPL (primary):  `keepassxc-cli open --yubikey <slot> --no-password <db>`
#     Emits "> " on stdout (initial prompt), then loops reading commands from stdin.
#     Commands arrive pre-parsed by shlex.join (no db path, no --yubikey).
#     Prints output + "\n> " after each command so vault.run_cli()'s readuntil works.
#
#   Direct (secondary):  attachment-export (run_cli_binary), import + merge (import_entries)
#     Called as a plain subprocess with full args including --yubikey and db path.

# --- Shared command handler ---
# Called in a subshell for REPL mode; called inline for direct mode.
# Receives: <subcmd> [args...] — no db path, no --yubikey.
_handle() {
    local subcmd="$1"; shift
    local SHOW_PROTECTED=0
    local NOTES_VALUE="" TITLE_VALUE="" USERNAME_VALUE="" PASSWORD_VALUE="" URL_VALUE=""
    local -a POS=()
    local i=0
    local -a args=("$@")

    while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
            --show-protected) SHOW_PROTECTED=1 ;;
            --stdout)         : ;;
            --notes)      i=$((i+1)); NOTES_VALUE="${args[$i]}" ;;
            --title)      i=$((i+1)); TITLE_VALUE="${args[$i]}" ;;
            --username)   i=$((i+1)); USERNAME_VALUE="${args[$i]}" ;;
            --password)   i=$((i+1)); PASSWORD_VALUE="${args[$i]}" ;;
            --url)        i=$((i+1)); URL_VALUE="${args[$i]}" ;;
            *) POS+=("${args[$i]}") ;;
        esac
        i=$((i+1))
    done

    case "$subcmd" in
        ls)
            local group="${POS[0]:-}"
            if [[ -z "$group" ]]; then
                printf 'Servers/\nSSH Keys/\nGPG Keys/\nGit/\nAPI Keys/\nServices/\nPersonal/\n'
            else
                case "$group" in
                    Servers)    printf 'test-server-1\ntest-server-2\n[INACTIVE] old-server\n' ;;
                    "SSH Keys") printf 'github-deploy-key\n' ;;
                    "API Keys") printf 'openai-key\n' ;;
                    Git)        printf 'github-token\n' ;;
                    *) ;;
                esac
            fi
            ;;
        show)
            local path_arg="${POS[0]:-}"
            local entry="${path_arg##*/}"
            if [[ $SHOW_PROTECTED -eq 1 ]]; then
                printf 'Title: %s\nUsername: admin\nPassword: s3cr3t!\nURL: https://example.com\nNotes: Test entry\n' "$entry"
            else
                printf 'Title: %s\nUsername: admin\nURL: https://example.com\nNotes: Test entry\n' "$entry"
            fi
            ;;
        search)
            local query="${POS[0]:-}"
            case "$query" in
                *server*|*test*) printf 'Servers/test-server-1\nServers/test-server-2\n' ;;
                *github*|*deploy*|*ssh*) printf 'SSH Keys/github-deploy-key\nGit/github-token\n' ;;
                *) ;;
            esac
            ;;
        attachment-export)
            # Binary export — always via run_cli_binary (direct mode), but handle in REPL too
            printf -- '-----BEGIN CERTIFICATE-----\nMIIBtestcertdata\n-----END CERTIFICATE-----\n'
            ;;
        add|edit|attachment-import)
            echo "Successfully completed ${subcmd}." >&2
            ;;
        *)
            echo "fake-keepassxc-cli: unknown subcommand: ${subcmd}" >&2
            return 1
            ;;
    esac
}

# --- Top-level: strip known flags, collect positional args ---

i=0
args=("$@")
declare -a POSITIONAL=()

while [[ $i -lt ${#args[@]} ]]; do
    case "${args[$i]}" in
        --yubikey|-y) i=$((i+1)) ;;   # skip slot value
        --no-password|--set-password|--stdout) : ;;
        *) POSITIONAL+=("${args[$i]}") ;;
    esac
    i=$((i+1))
done

SUBCMD="${POSITIONAL[0]:-}"

case "$SUBCMD" in

    open)
        # vault.unlock(): keepassxc-cli open --yubikey <slot> --no-password <db>
        # Start the REPL: emit initial "> " prompt, then loop processing commands.
        echo "Successfully opened database." >&2
        printf "> "

        # Commands arrive as shlex.join output: shell-quoted, newline-terminated.
        # eval splits them back into an array, handling quoted args with spaces.
        # stdout: command output (if any) followed by "\n> " for readuntil(b"\n> ").
        while IFS= read -r repl_line; do
            [[ -z "$repl_line" ]] && break
            eval "repl_cmd_array=($repl_line)"
            repl_subcmd="${repl_cmd_array[0]:-}"
            repl_output=$(_handle "$repl_subcmd" "${repl_cmd_array[@]:1}")
            if [[ -n "$repl_output" ]]; then
                printf '%s\n> ' "$repl_output"
            else
                printf '\n> '
            fi
        done
        ;;

    import)
        # import_entries staging: keepassxc-cli import --set-password <xml> <db>
        # Reads two password confirmations from stdin; creates an empty staging file.
        read -r _pass1; read -r _pass2
        staging_db="${POSITIONAL[2]:-}"
        [[ -n "$staging_db" ]] && touch "$staging_db" 2>/dev/null
        echo "Successfully imported database." >&2
        ;;

    merge)
        # import_entries merge: keepassxc-cli merge --yubikey <slot> --no-password <db> <staging>
        # Reads staging password from stdin; does nothing (fixture merge always succeeds).
        read -r _pass
        echo "Successfully merged database." >&2
        ;;

    attachment-export)
        # run_cli_binary: keepassxc-cli attachment-export --yubikey <slot> --no-password <db> <path> [--stdout]
        printf -- '-----BEGIN CERTIFICATE-----\nMIIBtestcertdata\n-----END CERTIFICATE-----\n'
        ;;

    *)
        echo "fake-keepassxc-cli: unknown subcommand: ${SUBCMD}" >&2
        exit 1
        ;;
esac
