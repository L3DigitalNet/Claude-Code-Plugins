{
  "name": "plugin-test-harness",
  "version": "0.7.7",
  "description": "Iterative live testing harness for Claude Code plugins and MCP servers",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc --noEmit && node esbuild.config.mjs",
    "dev": "tsx watch src/index.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=test/unit",
    "lint": "eslint src test",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.5.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "hono": ">=4.12.14",
    "ip-address": ">=10.1.1",
    "qs": ">=6.15.2",
    "fast-uri": ">=3.1.2"
  }
}
