# Annotated /etc/mdadm/mdadm.conf
#
# Each directive includes: what it does, default value, and when to change it.
# Directive order follows typical production layout (global config → arrays → policy).
#
# Debian/Ubuntu path: /etc/mdadm/mdadm.conf
# RHEL/Fedora path:   /etc/mdadm.conf
#
# After any change: run `update-initramfs -u` (Debian) or `dracut -f` (RHEL) so
# the initramfs picks up the updated config. Without this, changes take effect on
# a running system but NOT on next boot if the root FS is on a RAID array.
#
# Ground truth for current array config: `mdadm --detail --scan`
# Regenerate this file cleanly: `mdadm --detail --scan > /etc/mdadm/mdadm.conf`
# (Use > not >> — appending accumulates stale entries that cause assembly warnings.)

# ---------------------------------------------------------------------------
# GLOBAL SETTINGS
# ---------------------------------------------------------------------------

# HOMEHOST: the expected hostname for arrays created on this machine.
# Default: <system>  (uses the actual hostname at creation time)
# Change when: you are sharing disks between machines (e.g. moving a disk to a
#   new host). Arrays whose homehost does not match are not auto-assembled unless
#   you pass --force or set AUTO to include "foreign".
# "<system>" is a literal token meaning "use the current system hostname".
HOMEHOST <system>

# MAILADDR: address that receives mdadm monitor event emails.
# Default: not set (no email sent)
# Change when: you want failure alerts. Requires a working MTA (postfix, msmtp, etc.).
# Also configure MAILFROM and PROGRAM below for full alerting.
MAILADDR root@localhost

# MAILFROM: the From: address used in alert emails.
# Default: not set (MTA default)
# Change when: your MTA requires a specific envelope sender or you want replies
#   to go to a specific address.
# MAILFROM mdadm-monitor@hostname.example.com

# PROGRAM: path to a script called on any monitor event instead of (or in addition
# to) sending mail. The script receives the event name and device as arguments.
# Default: not set
# Change when: you want custom alerting (PagerDuty, Slack webhook, etc.).
# PROGRAM /usr/local/bin/mdadm-alert.sh

# MONITORDELAY: seconds between monitor poll cycles.
# Default: 60
# Change when: you want faster failure detection (lower value, higher CPU cost)
#   or are on a resource-constrained system (higher value).
MONITORDELAY 60

# ---------------------------------------------------------------------------
# AUTO: DEVICE AUTO-ASSEMBLY POLICY
# ---------------------------------------------------------------------------

# AUTO: controls which arrays mdadm will auto-assemble at boot via --assemble --scan.
# Default: +all  (assemble any array whose superblock is found)
# Tokens: +all, -all, +homehost, -homehost, +foreign, -foreign, +<version>,
#         where <version> is a superblock version (0.90, 1.0, 1.1, 1.2).
#
# Examples:
#   AUTO +homehost -foreign    — only assemble arrays created on this host; ignore foreign disks
#   AUTO +all                  — assemble everything found (default behavior)
#   AUTO -all +homehost        — same as +homehost -foreign but explicit order
#
# Change when: you attach disks from other machines and want to prevent accidental
#   assembly, or you are migrating arrays between hosts.
AUTO +all

# ---------------------------------------------------------------------------
# DEVICE LINES
# ---------------------------------------------------------------------------

# DEVICE: which block devices mdadm should scan when looking for array members.
# Default: partitions (scan /proc/partitions for all known partitions)
# Change when: you want to limit scanning to specific devices (faster, safer in
#   environments with many non-RAID disks) or include specific paths.
#
# "partitions" — scan all entries in /proc/partitions (most common)
# "containers" — also scan for Intel IMSM and DDF container formats
# Explicit paths: list specific devices or globs
#
# Examples:
#   DEVICE partitions          — scan everything in /proc/partitions
#   DEVICE /dev/sd[a-z]        — only bare disks, not partitions
#   DEVICE /dev/sdb1 /dev/sdc1 — only these two partitions
DEVICE partitions

# ---------------------------------------------------------------------------
# ARRAY LINES
# ---------------------------------------------------------------------------
# Each ARRAY line tells mdadm how to assemble a specific array.
# The UUID is the canonical identifier and is never reused across arrays.
#
# Generated by: `mdadm --detail --scan`
# Verify with:  `mdadm --examine /dev/sdXN` to see the UUID stored on a disk.
#
# Fields:
#   /dev/mdN       — the md device node to create (can be any available name)
#   metadata=1.2   — superblock version (0.90 = legacy at end of disk; 1.x = at start)
#   name=hostname:0 — array name embedded in superblock; used when HOMEHOST check passes
#   UUID=...       — unique identifier; required for unambiguous assembly
#   level=         — RAID level (1, 5, 6, 10, etc.)
#   num-devices=   — number of active (non-spare) member devices
#   spares=        — number of hot spare devices configured in the array

# RAID-1 example (two-disk mirror, no spares)
# Change when: UUID changes (it never should), or you rename the md device.
ARRAY /dev/md0 metadata=1.2 name=myhost:0 UUID=xxxxxxxx:xxxxxxxx:xxxxxxxx:xxxxxxxx level=raid1 num-devices=2

# RAID-5 example (three active disks, one hot spare)
ARRAY /dev/md1 metadata=1.2 name=myhost:1 UUID=yyyyyyyy:yyyyyyyy:yyyyyyyy:yyyyyyyy level=raid5 num-devices=3 spares=1

# RAID-6 example (four active disks)
ARRAY /dev/md2 metadata=1.2 name=myhost:2 UUID=zzzzzzzz:zzzzzzzz:zzzzzzzz:zzzzzzzz level=raid6 num-devices=4

# RAID-10 example (four active disks, near layout)
ARRAY /dev/md3 metadata=1.2 name=myhost:3 UUID=aaaaaaaa:aaaaaaaa:aaaaaaaa:aaaaaaaa level=raid10 num-devices=4

# ---------------------------------------------------------------------------
# POLICY LINES (optional, superblock v1.x only)
# ---------------------------------------------------------------------------

# POLICY: defines automatic hot-spare assignment rules based on disk attributes.
# Useful when disks are added to the system and you want them automatically
# claimed as spares for matching arrays without manual intervention.
#
# Default: not set (no automatic spare assignment)
# Change when: you have a large JBOD with many disks and want automatic spare pooling.
#
# action=spare     — claim matching disks as spares for arrays in the given domain
# action=include   — include matching disks in existing arrays if slots are available
# domain=          — arbitrary name grouping arrays and disks together
# path=            — sysfs path glob to match specific disk slots/controllers
# metadata=        — superblock version the policy applies to
#
# Example: automatically assign any disk plugged into enclosure sas0 as a spare
#   for arrays with metadata=1.2 in domain "pool":
# POLICY domain=pool metadata=1.2 action=spare path=pci-0000:00:1f.2-ata-*

# ---------------------------------------------------------------------------
# /proc/mdstat FORMAT REFERENCE
# ---------------------------------------------------------------------------
# Reading /proc/mdstat — what each field means:
#
# Personalities : [raid1] [raid6] [raid5] [raid10]
#   — kernel RAID modules currently loaded
#
# md0 : active raid1 sdc1[1] sdb1[0]
#   — array name, state (active/inactive/read-auto), level, member devices
#   — [N] after each device = position in array (slot index)
#   — (F) suffix = faulty/failed device
#   — (S) suffix = spare device
#   — (W) suffix = write-mostly device
#
#       100663296 blocks super 1.2 [2/2] [UU]
#   — total blocks in array
#   — super version
#   — [total_devices/active_devices]
#   — [UU] = device bitmap: U = up/active, _ = missing or failed
#     RAID-1 with 2 disks: [UU] = healthy, [U_] = degraded
#     RAID-5 with 3 disks: [UUU] = healthy, [UU_] = degraded (1 disk, still accessible)
#     RAID-6 with 4 disks: [UUUU] = healthy, [UU__] = degraded but still accessible
#
#       [=====>............]  recovery = 33.2% (33554432/100663296) finish=8.1min speed=100000K/sec
#   — sync_action: recovery (rebuild), resync, check, or repair
#   — percentage complete
#   — blocks done / total blocks
#   — estimated finish time at current speed
#   — current sync speed in KB/sec
#
#       bitmap: 1/1 pages [4KB], 65536KB chunk
#   — write intent bitmap (WIB) status: pages used / total, chunk size
#   — present only when --bitmap=internal was used at create/grow time
#
# unused devices: <none>
#   — md devices allocated but not in any array (normally <none>)
#
# Full healthy RAID-5 example:
#
#   Personalities : [raid6] [raid5] [raid4]
#   md0 : active raid5 sdd1[3] sdc1[2] sdb1[1] sda1[0]
#         293601280 blocks super 1.2 level 5, 512k chunk, algorithm 2 [4/4] [UUUU]
#         bitmap: 0/2 pages [0KB], 65536KB chunk
#   unused devices: <none>
