# Immich: Annotated .env and docker-compose.yml Reference
#
# Immich is configured almost entirely via the .env file. The docker-compose.yml
# from the official install guide should be used largely unmodified; customization
# happens in .env and through volume/device additions in compose overrides.
#
# Download the official files:
#   wget -O docker-compose.yml https://github.com/immich-app/immich/releases/latest/download/docker-compose.yml
#   wget -O .env              https://github.com/immich-app/immich/releases/latest/download/example.env
#
# Always use the compose file that matches your pinned IMMICH_VERSION — older
# compose files may reference removed services or missing variables.

# ===========================================================================
# .env FILE — KEY VARIABLES
# ===========================================================================

# Path on the Docker host where uploaded media is stored.
# Immich stores originals, thumbnails, video transcodes, and CLIP encodings
# here. This path MUST exist and be writable by the Docker process.
# Plan for 2–3× your raw photo volume (thumbnails and transcodes add up).
# Default: /us/src/app/upload  |  Recommended: a dedicated path on a large volume
# Change when: you want uploads on a separate disk or NFS mount.
UPLOAD_LOCATION=/mnt/photos/immich

# Password for the PostgreSQL database user.
# Auto-generated by the install instructions. Keep this in sync with the
# DB_PASSWORD used by the database service in docker-compose.yml.
# Change when: rotating credentials (requires updating both .env and the DB user).
DB_PASSWORD=your_generated_password_here

# Immich release version to use. Pin this explicitly — "release" tag is the
# latest stable, but it can update unexpectedly on `docker compose pull`.
# Pinning prevents accidental upgrades; bump it intentionally after reading
# the release notes at https://github.com/immich-app/immich/releases.
# Default: release  |  Recommended: pin to a specific version, e.g. v1.120.0
IMMICH_VERSION=v1.120.0

# Path on the Docker host for PostgreSQL data files.
# This directory must persist between container restarts. Losing it means
# losing all metadata, albums, users, and face data (not the photos themselves,
# but the entire library structure).
# Default: ./postgres  |  Recommended: explicit absolute path outside the compose dir
DB_DATA_LOCATION=/mnt/data/immich-postgres

# PostgreSQL connection details — keep in sync with database service config.
# These rarely need changing unless you're using an external database.
DB_HOSTNAME=database
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Redis connection — matches the redis service name in docker-compose.yml.
# Only change if you're using an external Redis instance.
REDIS_HOSTNAME=redis

# ===========================================================================
# docker-compose.yml STRUCTURE — WHAT EACH SERVICE DOES
# ===========================================================================

# ---- immich-server --------------------------------------------------------
# The core API and web UI. Handles HTTP requests on port 2283, manages uploads,
# serves the photo browser, and enqueues background jobs into Redis.
# Memory: ~256 MB base, more under heavy API load.
# This is the only container that needs its port exposed to the host.

# ---- immich-microservices -------------------------------------------------
# Background job worker. Consumes jobs from the Redis queue:
#   - thumbnail generation (preview, thumbnail sizes)
#   - metadata extraction (EXIF, GPS, duration)
#   - video transcoding (to a web-compatible format)
#   - CLIP embedding (for semantic/natural-language search)
#   - face detection coordination with the ML container
# Memory: 256–512 MB baseline; spikes during video transcoding.
# Can be scaled to multiple replicas for faster processing of large libraries.

# ---- immich-machine-learning ----------------------------------------------
# Runs CLIP (semantic search) and InsightFace (face detection/recognition)
# models. Communicates with immich-server over HTTP (MACHINE_LEARNING_URL).
# Memory: 2–4 GB under load; models are loaded lazily and cached in memory.
# Optional: set MACHINE_LEARNING_ENABLED=false in .env to skip this container
# entirely. The rest of Immich functions normally without it.

# ---- database (PostgreSQL) ------------------------------------------------
# Uses the Immich-provided postgres image that bundles the pgvecto-rs extension
# (required for vector similarity search). A plain postgres:16 image will fail
# on startup with extension errors — do NOT substitute it.
# Memory: 256–512 MB typical; grows with library size and query load.
# Healthcheck: the compose file includes a healthcheck; wait for it before
# starting immich-server (depends_on: condition: service_healthy).

# ---- redis ----------------------------------------------------------------
# Job queue broker. Lightweight — typically < 64 MB.
# Immich uses Redis for queuing thumbnail/ML/sync jobs between immich-server
# and immich-microservices. Data is ephemeral (jobs, not photos).

# ===========================================================================
# HARDWARE TRANSCODING (VIDEO)
# ===========================================================================

# Immich supports hardware-accelerated video transcoding via FFmpeg.
# Configure in the web UI under Administration → Transcoding Settings.
#
# Intel Quick Sync (iGPU — most common on home servers):
# Add to the immich-microservices service in docker-compose.yml:
#
#   devices:
#     - /dev/dri:/dev/dri
#
# Then in Immich web UI → Administration → Transcoding Settings:
#   - Hardware acceleration: Intel Quick Sync Video (QSV)
#   - Codec: h264 (or hevc if supported)
#
# NVIDIA (requires nvidia-container-toolkit on host):
# Add to docker-compose.yml:
#
#   deploy:
#     resources:
#       reservations:
#         devices:
#           - driver: nvidia
#             count: 1
#             capabilities: [gpu]
#
# Then set Hardware acceleration to NVENC in the UI.
#
# Verify transcoding is working:
#   docker compose logs immich-microservices | grep -i transcode

# ===========================================================================
# EXTERNAL LIBRARY CONFIGURATION
# ===========================================================================

# External libraries let Immich index photos that already exist on disk
# without moving them into the UPLOAD_LOCATION managed store.
# The source path must be mounted into the immich-server AND
# immich-microservices containers as a read-only volume.
#
# In docker-compose.yml, add to both immich-server and immich-microservices:
#
#   volumes:
#     - /mnt/nas/photos:/mnt/media/photos:ro
#
# Then in the web UI: Administration → External Libraries → Create Library,
# set the import path to /mnt/media/photos, and trigger a scan.
#
# Scans are not automatic. Options for regular syncing:
#   - Manual: click "Scan All" in the UI
#   - Cron: docker compose exec immich-server immich-admin library scan <id>
#   - Immich has a built-in scheduled scan interval per library (set in UI)

# ===========================================================================
# BACKUP STRATEGY
# ===========================================================================

# TWO things must be backed up — losing either one makes the library unusable.
#
# 1. PostgreSQL database — contains all metadata, albums, users, faces, tags.
#    Recommended approach: pg_dumpall into a compressed file, rotated daily.
#
#    docker compose exec -T database \
#      pg_dumpall -U postgres \
#      | gzip > /backup/immich-db-$(date +%F).sql.gz
#
#    Or use pg_dump for just the immich database:
#    docker compose exec -T database \
#      pg_dump -U postgres immich \
#      | gzip > /backup/immich-db-$(date +%F).sql.gz
#
# 2. Upload directory (UPLOAD_LOCATION) — the actual photo and video files,
#    plus thumbnails and transcoded versions.
#    Use rsync, restic, borgbackup, or rclone to sync to an off-host target.
#
#    rsync -av --delete $UPLOAD_LOCATION /backup/immich-uploads/
#
# Backup order: database first (consistent snapshot), then files.
# Restore order: files first, then database import, then restart the stack.
#
# Optional: Immich has a built-in backup feature (Administration → Backup) that
# can export a database dump on a schedule — useful as a secondary safety net,
# but not a substitute for off-host backups.

# ===========================================================================
# MEMORY RECOMMENDATIONS
# ===========================================================================

# Component                      Minimum    Comfortable    Notes
# immich-server                  256 MB     512 MB         API load spikes on large albums
# immich-microservices           256 MB     512 MB         spikes during video transcode
# immich-machine-learning        1 GB       4 GB           CLIP + InsightFace both load into RAM
# database (PostgreSQL)          256 MB     512 MB         grows with library + query complexity
# redis                          64 MB      128 MB         ephemeral; rarely the bottleneck
#
# Total minimum (with ML):  ~2 GB
# Comfortable (with ML):    ~6 GB
# Without ML container:     subtract 1–4 GB
#
# If the host has < 4 GB RAM, disable machine learning:
# MACHINE_LEARNING_ENABLED=false in .env
