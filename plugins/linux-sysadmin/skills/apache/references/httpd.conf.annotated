# Annotated Apache HTTP Server config
# Each directive includes: what it does, default value, recommended production value,
# and when to change it.
#
# This file covers both:
#   - Main server config (the global section before any VirtualHost blocks)
#   - VirtualHost blocks (HTTP, HTTPS/SSL, PHP-FPM proxy)
#
# Debian path:  /etc/apache2/apache2.conf  (includes sites-enabled/* for vhosts)
# RHEL path:    /etc/httpd/conf/httpd.conf  (includes conf.d/*.conf for vhosts)

# ---------------------------------------------------------------------------
# SERVER ROOT
# ---------------------------------------------------------------------------

# Base directory for all relative paths in this config.
# Default: /etc/httpd (RHEL) or /etc/apache2 (Debian)
# Change when: running Apache from a non-standard install prefix.
ServerRoot "/etc/apache2"

# ---------------------------------------------------------------------------
# LISTENING
# ---------------------------------------------------------------------------

# Ports and addresses to accept connections on.
# Default: Listen 80
# Change when: binding to a specific interface (e.g., Listen 192.168.1.1:80),
#   or adding HTTPS (add Listen 443).
Listen 80
Listen 443

# ---------------------------------------------------------------------------
# MODULES
# ---------------------------------------------------------------------------

# Dynamic module loading. Each LoadModule line enables one Apache module.
# Default: package installs include a standard set; Debian uses a2enmod.
# Change when: you need a module not in the default set, or to reduce attack
#   surface by disabling unused modules.
#
# On Debian, modules are managed via a2enmod/a2dismod and symlinks in
# mods-enabled/. On RHEL, edit /etc/httpd/conf.modules.d/*.conf.
#
# Key modules for common use cases:
LoadModule rewrite_module modules/mod_rewrite.so   # URL rewriting (.htaccess RewriteRule)
LoadModule ssl_module modules/mod_ssl.so           # HTTPS/TLS support
LoadModule proxy_module modules/mod_proxy.so       # Reverse proxy base
LoadModule proxy_http_module modules/mod_proxy_http.so  # HTTP proxy backend
LoadModule proxy_fcgi_module modules/mod_proxy_fcgi.so  # PHP-FPM via FastCGI
LoadModule headers_module modules/mod_headers.so   # Header manipulation (HSTS, etc.)
LoadModule expires_module modules/mod_expires.so   # Cache-Control / Expires headers
LoadModule deflate_module modules/mod_deflate.so   # Gzip response compression
LoadModule auth_basic_module modules/mod_auth_basic.so  # HTTP Basic Auth
LoadModule authn_file_module modules/mod_authn_file.so  # htpasswd file backend
LoadModule authz_host_module modules/mod_authz_host.so  # IP-based access control
LoadModule authz_user_module modules/mod_authz_user.so  # User-based access control

# ---------------------------------------------------------------------------
# USER AND GROUP
# ---------------------------------------------------------------------------

# Unix user and group Apache worker processes run as.
# Default: www-data (Debian), apache (RHEL)
# Change when: running multiple sites that need process-level isolation
#   (unusual — prefer filesystem permissions or PHP-FPM pools instead).
# NEVER set to root.
User www-data
Group www-data

# ---------------------------------------------------------------------------
# SERVER IDENTITY
# ---------------------------------------------------------------------------

# Email shown in server-generated error pages and used for abuse contact.
# Default: root@localhost  |  Recommended: your actual admin address
# Change when: you want errors to show a useful contact.
ServerAdmin webmaster@example.com

# Hostname and port the server uses to construct self-referential URLs.
# Default: not set (Apache guesses from DNS, which causes AH00558 warning)
# Recommended: set explicitly to avoid the warning and wrong redirect targets.
# Change when: the server has multiple hostnames — set to the primary FQDN.
ServerName example.com

# Whether to include Apache version and OS in the Server response header.
# Default: Full  |  Options: Full, Minor, Major, Prod, OS
# Recommended: Prod (hides version and OS, reduces information disclosure)
# Change when: debugging requires knowing the exact version from headers.
ServerTokens Prod

# Whether to include Apache version in error pages generated by the server.
# Default: On  |  Recommended: Off
# Change when: you need version info in error pages for debugging.
ServerSignature Off

# ---------------------------------------------------------------------------
# DOCUMENT ROOT AND DIRECTORY DEFAULTS
# ---------------------------------------------------------------------------

# The filesystem directory that maps to the server's root URL (/).
# Default: /var/www/html (Debian), /var/www/html (RHEL)
# Change when: your site files live elsewhere.
DocumentRoot "/var/www/html"

# Default permissions for the filesystem root. Locks down everything above
# DocumentRoot so Apache can't accidentally serve files outside web dirs.
# Default: Indexes FollowSymLinks (permissive)  |  Recommended: None
# Change when: you need specific behavior — add only what is required.
<Directory />
    Options None
    AllowOverride None
    Require all denied
</Directory>

# Permissions for the DocumentRoot itself.
# Options:
#   Indexes     — show directory listings when no index file exists (disable in prod)
#   FollowSymLinks — required for mod_rewrite to function
#   -Indexes    — explicitly disable directory listings
# AllowOverride: which directives .htaccess files may override.
#   None   — ignore .htaccess entirely (best for performance)
#   All    — allow all overrides (convenient but costly; see Pain Points)
#   FileInfo, AuthConfig, Limit, Options — grant specific override classes only
# Require all granted — allow any client to access this directory.
<Directory "/var/www/html">
    Options -Indexes +FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

# Prevent clients from accessing .htaccess and .htpasswd files directly.
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# Error log destination and verbosity.
# Default: logs/error_log  |  Recommended: explicit path, warn level
# Levels: emerg, alert, crit, error, warn, notice, info, debug
# Change when: debugging a specific issue (raise to info or debug temporarily).
ErrorLog "/var/log/apache2/error.log"
LogLevel warn

# Named log format strings. "combined" is the Common Log Format + Referer/UA.
# "%D" adds request processing time in microseconds — useful for perf diagnosis.
# Default: main and combined formats defined in logging config
# Change when: you need additional fields (e.g., SSL cipher, virtual host name).
LogFormat "%h %l %u %t \"%r\" %>s %O \"%{Referer}i\" \"%{User-Agent}i\"" combined
LogFormat "%h %l %u %t \"%r\" %>s %O \"%{Referer}i\" \"%{User-Agent}i\" %D" combined_time
LogFormat "%h %l %u %t \"%r\" %>s %O" common

# Access log destination and format for the default/catch-all vhost.
# Default: logs/access_log  |  Recommended: explicit path, combined format
# Change when: per-vhost access logs are preferred (set CustomLog in each VirtualHost).
CustomLog "/var/log/apache2/access.log" combined

# ---------------------------------------------------------------------------
# MIME TYPES
# ---------------------------------------------------------------------------

# File mapping file extensions to Content-Type response headers.
# Default: /etc/mime.types or mime.magic  |  Recommended: always include
TypesConfig /etc/mime.types

# Fallback MIME type for files with unrecognized extensions.
# Default: text/plain  |  Recommended: application/octet-stream (forces download)
DefaultType application/octet-stream

# ---------------------------------------------------------------------------
# INCLUDES
# ---------------------------------------------------------------------------

# Load additional config from conf-available/ snippets enabled via a2enconf.
# Debian-specific: RHEL uses conf.d/ directly.
IncludeOptional conf-enabled/*.conf

# Load VirtualHost definitions. Debian uses sites-enabled/ symlinks.
# RHEL: replace with IncludeOptional conf.d/*.conf
IncludeOptional sites-enabled/*.conf

# ---------------------------------------------------------------------------
# VIRTUAL HOST: HTTP (port 80)
# ---------------------------------------------------------------------------
# Place this block in /etc/apache2/sites-available/example.com.conf
# Enable with: sudo a2ensite example.com.conf && sudo systemctl reload apache2

<VirtualHost *:80>
    # Hostname this vhost responds to. Apache matches the Host header against this.
    # Requests that don't match any ServerName go to the first defined vhost on the port.
    ServerName example.com

    # Additional names that map to the same vhost (e.g., www. prefix).
    ServerAlias www.example.com

    # Contact address shown in server-generated error pages for this vhost.
    ServerAdmin webmaster@example.com

    # Root directory for this vhost's content.
    DocumentRoot /var/www/example.com

    <Directory /var/www/example.com>
        # FollowSymLinks is required for RewriteRule to work in mod_rewrite.
        # -Indexes disables directory listings; remove the minus to enable them.
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    # Vhost-specific access log. Separates traffic per site for easier analysis.
    # Default: inherits from global CustomLog if not set
    CustomLog /var/log/apache2/example.com-access.log combined

    # Vhost-specific error log. Makes debugging per-site issues much easier.
    ErrorLog /var/log/apache2/example.com-error.log

    # Custom error pages for this vhost.
    # Default: Apache's built-in error pages
    # Change when: you want branded error pages.
    ErrorDocument 404 /errors/404.html
    ErrorDocument 500 /errors/50x.html
</VirtualHost>

# ---------------------------------------------------------------------------
# VIRTUAL HOST: HTTPS / SSL (port 443)
# ---------------------------------------------------------------------------
# Requires mod_ssl: sudo a2enmod ssl && sudo systemctl reload apache2
# Certbot places Let's Encrypt certs at /etc/letsencrypt/live/<domain>/

<VirtualHost *:443>
    ServerName example.com
    ServerAlias www.example.com
    ServerAdmin webmaster@example.com
    DocumentRoot /var/www/example.com

    # Enable TLS for this vhost.
    # Default: Off  |  Required for HTTPS.
    SSLEngine On

    # Path to the server's certificate. Use fullchain.pem (cert + intermediates)
    # so browsers that don't do OCSP can verify the full chain.
    # Default: not set  |  Required.
    SSLCertificateFile /etc/letsencrypt/live/example.com/fullchain.pem

    # Path to the private key corresponding to the certificate.
    # Default: not set  |  Required. Protect this file: chmod 600, owned by root.
    SSLCertificateKeyFile /etc/letsencrypt/live/example.com/privkey.pem

    # TLS protocol versions to accept. TLS 1.0 and 1.1 are deprecated.
    # Default: all (including old versions in older Apache)
    # Recommended: -all +TLSv1.2 +TLSv1.3
    # Change when: you must support legacy clients that lack TLS 1.2 (rare).
    SSLProtocol -all +TLSv1.2 +TLSv1.3

    # Cipher suite string. Use Mozilla SSL config generator for current recommendations.
    # Default: DEFAULT (Apache's built-in set, may include weak ciphers)
    # Recommended: Mozilla Intermediate compatibility profile
    # Change when: you need FIPS compliance or must exclude specific ciphers.
    SSLCipherSuite ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384

    # TLS 1.3 cipher suites (separate directive, TLS 1.3 has its own list).
    # Default: OpenSSL's built-in TLS 1.3 defaults (generally safe)
    # Change when: regulatory requirements mandate specific TLS 1.3 suites.
    SSLCipherSuite TLSv1.3 TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256

    # Whether the server's cipher preference takes priority over the client's.
    # Default: Off  |  Recommended: Off for TLS 1.3 (clients have good defaults);
    #   On for TLS 1.2 if you want to enforce cipher order.
    SSLHonorCipherOrder Off

    # OCSP stapling: Apache fetches and caches the cert revocation status so
    # clients don't query the CA directly. Requires outbound HTTPS from server.
    # Default: Off  |  Recommended: On for public-facing HTTPS.
    SSLUseStapling On

    # Shared cache for OCSP stapling responses. Must be defined outside VirtualHost
    # (at server or global level). The "shmcb" type is an in-memory shared cache.
    # SSLStaplingCache shmcb:/var/run/ocsp(128000)   <- put this in apache2.conf

    # HTTP Strict Transport Security: tells browsers to only use HTTPS for 2 years.
    # Remove includeSubDomains if any subdomain is HTTP-only.
    # Only set in HTTPS vhosts — sending HSTS over HTTP is useless and confusing.
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"

    # Prevent MIME type sniffing in browsers.
    Header always set X-Content-Type-Options "nosniff"

    # Deny clickjacking attacks by preventing embedding in iframes from other origins.
    Header always set X-Frame-Options "SAMEORIGIN"

    # Referrer policy: limit how much URL info is sent to third-party sites.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    <Directory /var/www/example.com>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    CustomLog /var/log/apache2/example.com-ssl-access.log combined
    ErrorLog /var/log/apache2/example.com-ssl-error.log
</VirtualHost>

# ---------------------------------------------------------------------------
# VIRTUAL HOST: PHP-FPM via Unix socket
# ---------------------------------------------------------------------------
# Requires mod_proxy and mod_proxy_fcgi:
#   sudo a2enmod proxy proxy_fcgi && sudo systemctl reload apache2
# PHP-FPM socket path depends on PHP version; check /etc/php/<version>/fpm/pool.d/www.conf

<VirtualHost *:443>
    ServerName phpapp.example.com
    ServerAdmin webmaster@example.com
    DocumentRoot /var/www/phpapp

    SSLEngine On
    SSLCertificateFile /etc/letsencrypt/live/phpapp.example.com/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/phpapp.example.com/privkey.pem
    SSLProtocol -all +TLSv1.2 +TLSv1.3

    <Directory /var/www/phpapp>
        # AllowOverride FileInfo needed if the app uses .htaccess for routing.
        # Prefer setting directives here in the vhost block (AllowOverride None).
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    # Pass all .php requests to PHP-FPM via the FastCGI proxy.
    # "unix:/run/php/php8.2-fpm.sock|" — the pipe character is required; it separates
    # the socket path from the fcgi:// URL that follows.
    # Replace php8.2 with your installed PHP version.
    # Default: not set  |  Required for PHP-FPM deployments.
    <FilesMatch \.php$>
        # SetHandler routes matching files to the named proxy handler.
        SetHandler "proxy:unix:/run/php/php8.2-fpm.sock|fcgi://localhost"
    </FilesMatch>

    # Alternatively, use a ProxyPassMatch for older Apache versions:
    # ProxyPassMatch ^/(.*\.php(/.*)?)$ unix:/run/php/php8.2-fpm.sock|fcgi://localhost/var/www/phpapp/$1

    # Optional: deny direct access to PHP files outside DocumentRoot (extra protection).
    <LocationMatch "/(wp-admin|admin)">
        Require all granted
    </LocationMatch>

    CustomLog /var/log/apache2/phpapp-access.log combined
    ErrorLog /var/log/apache2/phpapp-error.log
</VirtualHost>
