#!/usr/bin/env bash
# PATH-prepended stub for the gh CLI. Behavior controlled by GH_STUB_MODE.
#   release_ok       — returns canned tagName/body for `gh release view ...` (default)
#   release_missing  — emits "HTTP 404: release not found" so api-retry.sh fails fast
#   http_429         — emits "HTTP 429: rate limited" so api-retry.sh retries
case "${GH_STUB_MODE:-release_ok}" in
  release_ok)
    if [[ "$*" == *"-q .tagName"* ]]; then echo "v1.0.0"; exit 0; fi
    if [[ "$*" == *"-q .body"* ]]; then echo "release notes"; exit 0; fi
    echo "gh-stub-ok"; exit 0 ;;
  release_missing) echo "HTTP 404: release not found" >&2; exit 1 ;;
  http_429)        echo "HTTP 429: rate limited" >&2; exit 1 ;;
  *) echo "gh-stub: unknown mode '${GH_STUB_MODE}'" >&2; exit 1 ;;
esac
