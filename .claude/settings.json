{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|resume|clear|compact",
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_start.py\"",
						"timeout": 30
					}
				]
			}
		]
	},
	"enabledPlugins": {
		"skill-creator@claude-plugins-official": true,
		"plugin-dev@claude-plugins-official": true
	}
}
